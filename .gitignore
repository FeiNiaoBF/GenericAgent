# ============================================================
# GenericAgent .gitignore
# Structure: A) Universal  B) Official GA  C) Fork (yeelight)
# ============================================================

# ============================================================
# PART A: UNIVERSAL IGNORES (all branches, all forks)
# ============================================================

# --- Workspace temp ---
temp/
tmp/

# --- Python artifacts ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
build/
dist/
*.egg-info/
**/__pycache__/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
.streamlit/
.vs/

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Sensitive / secrets ---
*.log
.env
auth.json
mykey.py

# --- Runtime / generated ---
tasks/
*.zip
model_responses.txt
.startup_pid
*.pid
ga_config.json
ga_config*.json
logs/
logs/**/*
*.spec
dist/
build/
restore_commit.txt
**log.*

# --- CDP Bridge auto-generated ---
assets/tmwd_cdp_bridge/config.js
assets/copilot_proxy.pyw


# ============================================================
# PART B: OFFICIAL GA WHITELIST (from upstream lsdefine/GenericAgent)
#   LEGACY entries (fork_sync,memory_cleanup,scheduled_task,web_setup)
#   are kept for upstream merge compat -- NOT FOUND warnings safe.
# ============================================================

# Blacklist all memory/, then whitelist specific SOPs/tools
memory/*
